# ADMIN_API_KEY protects GET /clicks (admin). Change this to a strong secret.
ADMIN_API_KEY=change-me-to-a-long-random-secret

# Base URL used by the link generator (public entrypoint).
BASE_URL=http://localhost:8084/

# --- Mailer (mailer/send_campaign.py) ---------------------------------------
# SMTP delivery settings. Use ONE provider account (Gmail or Outlook).
# With --provider gmail|outlook the host/port default to the right values,
# so you normally only need to set the username/password/from below.
#
# Gmail:   host smtp.gmail.com        port 587  (requires an App Password)
# Outlook: host smtp-mail.outlook.com port 587
SMTP_HOST=
SMTP_PORT=587
SMTP_STARTTLS=true

# Optional: tunnel the SMTP connection through a local proxy. Leave blank to
# connect directly. Schemes: socks5h:// (proxy resolves DNS, recommended),
# socks5://, http:// (HTTP CONNECT). A bare host:port defaults to socks5h.
# Example for the macOS system proxy shown at 127.0.0.1:15236:
#   SMTP_PROXY=socks5h://127.0.0.1:15236
SMTP_PROXY=

# Login credentials (username is usually the full email address).
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=your-app-password

# From header. SMTP_FROM defaults to SMTP_USERNAME if left blank.
SMTP_FROM=you@example.com
SMTP_FROM_NAME=Account Security

# Subject line for the campaign email.
EMAIL_SUBJECT=Action required: please verify your account

